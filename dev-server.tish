// Dev server for tish-learn. Serves public/ + content/.
// Run: tish run --feature http,fs,process dev-server.tish
import { fileExists, readFile, isDir } from "fs"
import { process } from "process"
import { serve } from "http"

const ROOTS = [".", "public"]

fn opt(o, key, fallback) {
  if (key in o) {
    let v = o[key]
    if (v !== null) { return v }
  }
  return fallback
}

fn contentType(path) {
  if (path.endsWith(".html")) { return "text/html; charset=utf-8" }
  if (path.endsWith(".css")) { return "text/css; charset=utf-8" }
  if (path.endsWith(".js")) { return "application/javascript; charset=utf-8" }
  if (path.endsWith(".wasm")) { return "application/wasm" }
  if (path.endsWith(".json")) { return "application/json" }
  if (path.endsWith(".tishdoc.md") || path.endsWith(".md")) { return "text/markdown; charset=utf-8" }
  if (path.endsWith(".svg")) { return "image/svg+xml" }
  if (path.endsWith(".png")) { return "image/png" }
  if (path.endsWith(".ico")) { return "image/x-icon" }
  return "application/octet-stream"
}

fn isBinary(path) {
  return path.endsWith(".wasm") || path.endsWith(".png") || path.endsWith(".ico")
}

fn resolveCandidates(reqPath) {
  let p = reqPath
  if (p === "/" || p === "") { return ["public/index.html"] }
  if (p.charAt(0) === "/") { p = p.substring(1) }
  // Look in `public/` first, then repo root (for /content/...).
  return ["public/" + p, p]
}

// Paths that must NEVER fall back to index.html — they're real assets or
// data that should 404 if missing so the client surfaces the right error.
fn isAssetPath(reqPath) {
  if (reqPath.indexOf("/dist/") === 0) { return true }
  if (reqPath.indexOf("/content/") === 0) { return true }
  if (reqPath.indexOf("/api/") === 0) { return true }
  // Anything with a file extension (last segment contains a dot)
  let lastSlash = reqPath.lastIndexOf("/")
  let lastSeg = lastSlash >= 0 ? reqPath.substring(lastSlash + 1) : reqPath
  return lastSeg.indexOf(".") >= 0
}

fn serveFile(path) {
  let ct = contentType(path)
  // Disable caching during development so browsers always pick up the
  // freshest learn.js / lattish-runtime.js / *.tishdoc.md after a rebuild.
  let headers = { "Content-Type": ct, "Cache-Control": "no-store" }
  if (isBinary(path)) {
    return { status: 200, headers: headers, file: path }
  }
  let body = readFile(path)
  if (body !== null && typeof body === "object" && "error" in body) {
    return { status: 500, body: "Error: " + body["error"] }
  }
  return { status: 200, headers: headers, body: body }
}

fn handleRequest(req) {
  let candidates = resolveCandidates(req.path)
  let i = 0
  while (i < candidates.length) {
    let path = candidates[i]
    if (fileExists(path) && !isDir(path)) { return serveFile(path) }
    i = i + 1
  }
  // SPA fallback: any non-asset path serves index.html so the History-API
  // router can take it from there.
  if (!isAssetPath(req.path) && fileExists("public/index.html")) {
    return serveFile("public/index.html")
  }
  return { status: 404, body: "Not found: " + req.path }
}

let port = 8765
if (process !== null && "env" in process && process.env !== null && "PORT" in process.env) {
  port = parseInt(process.env["PORT"])
}
console.log("tish-learn dev server: http://127.0.0.1:" + port)
serve(port, handleRequest)
